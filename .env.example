# ── Alisha IA — Configuración ────────────────────────────────────────────────
# Copiar este archivo a .env y completar con tus API keys

# ── IA y LLMs (al menos uno es obligatorio) ───────────────────────────────────
GROQ_API_KEY=                    # https://console.groq.com (gratis, recomendado)
MISTRAL_API_KEY=                 # https://console.mistral.ai (gratis)
GEMINI_API_KEY=                  # https://aistudio.google.com (gratis)
OPENAI_API_KEY=                  # https://platform.openai.com (pago)
GOOGLE_API_KEY=                  # Gemini alternativo

# ── Voz (opcional, usa edge-tts gratis si no está) ────────────────────────────
ELEVENLABS_API_KEY=              # https://elevenlabs.io (premium)

# ── Base de datos (opcional, usa SQLite local si no está) ─────────────────────
MONGO_URI=                       # mongodb://localhost:27017/ o MongoDB Atlas

# ── Canales externos ──────────────────────────────────────────────────────────
# Telegram Bot
TELEGRAM_ENABLED=false           # true para activar
TELEGRAM_BOT_TOKEN=              # Token del bot de @BotFather
TELEGRAM_ALLOWED_USER_IDS=       # IDs separados por coma: 123456,789012

# WhatsApp (no implementado aún)
WHATSAPP_ENABLED=false

# ── Modelo Live2D ─────────────────────────────────────────────────────────────
LIVE2D_MODEL_PATH=C:\Program Files (x86)\Steam\steamapps\common\VTube Studio\VTube Studio_Data\StreamingAssets\Live2DModels\IceGirl_Live2d\IceGIrl Live2D\IceGirl.model3.json

# ── Configuración avanzada ────────────────────────────────────────────────────
# Puerto del servidor web
PORT=5000

# Nivel de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
